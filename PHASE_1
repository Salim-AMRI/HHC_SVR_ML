def run_benchmark():
    fieldnames = [
        'instance', 'method', 'run', 'seed',
        'pre_ts_cost', 'post_ts_cost', 'post_ts_time_s',
        'feasible', 'valid', 'improvement_pct'
    ]
    with open(OUTPUT_CSV, 'w', newline='') as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        writer.writeheader()

    instance_cache = {}
    for inst_cfg in INSTANCES:
        file_path = os.path.join(INSTANCE_DIR, f"{inst_cfg['name']}.vrp")
        if not os.path.exists(file_path):
            raise FileNotFoundError(f"Fichier introuvable : {file_path}")
        coords, demands, dimension = load_instance(file_path)
        instance_cache[inst_cfg['name']] = (coords, demands, dimension)
        print(f"Instance {inst_cfg['name']} chargée : {dimension} clients")

    total_runs = len(INSTANCES) * len(METHODS) * N_RUNS
    run_counter = 0

    for inst_cfg in INSTANCES:
        inst_name = inst_cfg['name']
        coords, demands, dimension = instance_cache[inst_name]
        for method in METHODS:
            print(f"\nMéthode {method.upper()} sur {inst_name}")
            method_results = []
            for seed in SEEDS:
                run_counter += 1
                print(f"  Run {run_counter:3d}/{total_runs} (seed={seed})", end=' ', flush=True)
                solver = CVRPSolverOptimized(
                    coords=coords, demands=demands, dimension=dimension,
                    capacity=inst_cfg['capacity'],
                    num_vehicles=inst_cfg['num_vehicles'],
                    max_time=MAX_TIME,
                    tabu_tenure=TABU_TENURE,
                    init_method=method,
                    seed=seed,
                )
                pre_cost = solver.pre_ts_cost
                ts_start = time.time()
                final_sol = solver.tabu_search()
                ts_time = time.time() - ts_start
                post_cost = total_distance(final_sol, solver.dist)
                feasible = int(solver._is_feasible(final_sol))
                valid = int(solver._validate(final_sol))
                impr_pct = (pre_cost - post_cost) / pre_cost * 100 if pre_cost > 0 else 0.0
                print(f"→ pre={pre_cost:.0f} post={post_cost:.0f} Δ={impr_pct:+.1f}%")
                row = {
                    'instance': inst_name,
                    'method': method,
                    'run': run_counter,
                    'seed': seed,
                    'pre_ts_cost': round(pre_cost, 2),
                    'post_ts_cost': round(post_cost, 2),
                    'post_ts_time_s': round(solver.best_feasible_time if solver.best_feasible is not None else ts_time, 2),
                    'feasible': feasible,
                    'valid': valid,
                    'improvement_pct': round(impr_pct, 2),
                }
                method_results.append(row)
                with open(OUTPUT_CSV, 'a', newline='') as f:
                    writer = csv.DictWriter(f, fieldnames=fieldnames)
                    writer.writerow(row)
            pre_costs = [r['pre_ts_cost'] for r in method_results]
            post_costs = [r['post_ts_cost'] for r in method_results]
            print(f"  Résumé {inst_name} {method}: pre avg={np.mean(pre_costs):.0f} ± {np.std(pre_costs):.0f}, "
                  f"post avg={np.mean(post_costs):.0f} ± {np.std(post_costs):.0f}")

    print(f"\nBenchmark terminé. Résultats dans {OUTPUT_CSV}")


def analyse_results(csv_path=OUTPUT_CSV):
    from collections import defaultdict
    data = defaultdict(list)
    with open(csv_path, newline='') as f:
        for row in csv.DictReader(f):
            key = (row['instance'], row['method'])
            data[key].append({
                'pre': float(row['pre_ts_cost']),
                'post': float(row['post_ts_cost']),
            })
    methods = METHODS
    instances = [i['name'] for i in INSTANCES]
    print("\n" + "="*80)
    print("TABLE PRÉ-TS (moyenne ± écart-type)")
    print("="*80)
    header = f"{'Instance':<18}" + "".join(f"{m.upper():>20}" for m in methods)
    print(header)
    for inst in instances:
        row_str = f"{inst:<18}"
        for m in methods:
            vals = [d['pre'] for d in data[(inst, m)]]
            mean = np.mean(vals)
            std = np.std(vals)
            row_str += f"{mean:>12.0f} ±{std:>6.0f}"
        print(row_str)
    print("\n" + "="*80)
    print("TABLE POST-TS (moyenne ± écart-type)")
    print("="*80)
    print(header)
    for inst in instances:
        row_str = f"{inst:<18}"
        for m in methods:
            vals = [d['post'] for d in data[(inst, m)]]
            mean = np.mean(vals)
            std = np.std(vals)
            row_str += f"{mean:>12.0f} ±{std:>6.0f}"
        print(row_str)
    print("\n" + "="*80)
    print("AMÉLIORATION PRÉ→POST (%)")
    print("="*80)
    header2 = f"{'Instance':<18}" + "".join(f"{m.upper():>12}" for m in methods)
    print(header2)
    for inst in instances:
        row_str = f"{inst:<18}"
        for m in methods:
            pre_vals = [d['pre'] for d in data[(inst, m)]]
            post_vals = [d['post'] for d in data[(inst, m)]]
            impr = (np.mean(pre_vals) - np.mean(post_vals)) / np.mean(pre_vals) * 100
            row_str += f"{impr:>11.1f}%"
        print(row_str)


if __name__ == '__main__':
    run_benchmark()
    if os.path.exists(OUTPUT_CSV):
        analyse_results(OUTPUT_CSV)
