class InsertionBenchmark:
    def __init__(self, coords, demands, D, capacity,
                 static_clients, dynamic_clients, initial_routes):
        self.coords = coords
        self.demands = demands
        self.D = D
        self.capacity = capacity
        self.static = static_clients
        self.dynamic = dynamic_clients
        self.initial_routes = [r[:] for r in initial_routes]
        self.K = len(initial_routes)
        if static_clients:
            self.global_centroid = np.mean([coords[c] for c in static_clients], axis=0)
        else:
            self.global_centroid = np.array([0.,0.])
        self._update_route_centroids(self.initial_routes)

    def _update_route_centroids(self, routes):
        self.route_centroids = {
            ri: np.mean([self.coords[c] for c in r], axis=0) if r else self.global_centroid.copy()
            for ri, r in enumerate(routes)
        }

    def _fresh(self):
        return [r[:] for r in self.initial_routes]

    def _loads(self, routes):
        return [sum(self.demands[c] for c in r) for r in routes]

    def _best_pos(self, route, client):
        bp, bi = 0, float('inf')
        n = len(route)
        for pos in range(n+1):
            prev = route[pos-1] if pos>0 else 0
            nxt  = route[pos]   if pos<n else 0
            inc  = self.D[prev,client] + self.D[client,nxt] - self.D[prev,nxt]
            if inc < bi:
                bi, bp = inc, pos
        return bp, bi

    # Fallback pénalisé (uniquement si aucune route faisable)
    def _cheapest_fb_penalty(self, routes, loads, client):
        best_inc = float('inf')
        best_route = -1
        best_pos = -1
        for i, r in enumerate(routes):
            p, inc = self._best_pos(r, client)
            new_load = loads[i] + self.demands[client]
            penalty = max(0, (new_load - self.capacity)) * 1000
            total = inc + penalty
            if total < best_inc:
                best_inc = total
                best_route = i
                best_pos = p
        if best_route != -1:
            routes[best_route].insert(best_pos, client)
            loads[best_route] += self.demands[client]
        return best_route != -1

    # ---------- 1. Random (vraiment aléatoire) ----------
    def random_insertion(self):
        routes = self._fresh()
        loads = self._loads(routes)
        for c in self.dynamic:
            feas = [i for i in range(self.K) if loads[i] + self.demands[c] <= self.capacity]
            if feas:
                idx = random.choice(feas)
                p, _ = self._best_pos(routes[idx], c)
                routes[idx].insert(p, c)
                loads[idx] += self.demands[c]
            else:
                self._cheapest_fb_penalty(routes, loads, c)
        inserted = sum(len(r) for r in routes) - len(self.static)
        print(f"        random: insérés {inserted}/{len(self.dynamic)} clients")
        return routes

    # ---------- 2. Cheapest (pénalisé) ----------
    def cheapest_insertion(self):
        routes = self._fresh()
        loads = self._loads(routes)
        for c in self.dynamic:
            self._cheapest_fb_penalty(routes, loads, c)
        inserted = sum(len(r) for r in routes) - len(self.static)
        print(f"        cheapest: insérés {inserted}/{len(self.dynamic)} clients")
        return routes

    # ---------- 3. Regret-2 (pénalisé) ----------
    def regret2_insertion(self):
        routes = self._fresh()
        loads = self._loads(routes)
        remaining = list(self.dynamic)
        while remaining:
            best_regret = -float('inf')
            best_client = None
            best_route_idx = -1
            best_pos = -1
            progress = False
            for client in remaining:
                candidates = []
                for i, r in enumerate(routes):
                    p, inc = self._best_pos(r, client)
                    new_load = loads[i] + self.demands[client]
                    penalty = max(0, (new_load - self.capacity)) * 1000
                    total = inc + penalty
                    candidates.append((total, i, p))
                if not candidates:
                    continue
                progress = True
                candidates.sort(key=lambda x: x[0])
                regret = candidates[1][0] - candidates[0][0] if len(candidates) >= 2 else 0.0
                if regret > best_regret:
                    best_regret = regret
                    best_client = client
                    best_route_idx, best_pos = candidates[0][1], candidates[0][2]
            if best_client is None or not progress:
                break
            routes[best_route_idx].insert(best_pos, best_client)
            loads[best_route_idx] += self.demands[best_client]
            remaining.remove(best_client)
        inserted = sum(len(r) for r in routes) - len(self.static)
        print(f"        regret2: insérés {inserted}/{len(self.dynamic)} clients")
        return routes

    # ---------- 4. Regret-3 (pénalisé) ----------
    def regret3_insertion(self):
        routes = self._fresh()
        loads = self._loads(routes)
        remaining = list(self.dynamic)
        while remaining:
            best_regret = -float('inf')
            best_client = None
            best_route_idx = -1
            best_pos = -1
            progress = False
            for client in remaining:
                candidates = []
                for i, r in enumerate(routes):
                    p, inc = self._best_pos(r, client)
                    new_load = loads[i] + self.demands[client]
                    penalty = max(0, (new_load - self.capacity)) * 1000
                    total = inc + penalty
                    candidates.append((total, i, p))
                if not candidates:
                    continue
                progress = True
                candidates.sort(key=lambda x: x[0])
                if len(candidates) >= 3:
                    regret = (candidates[1][0] + candidates[2][0])/2.0 - candidates[0][0]
                elif len(candidates) == 2:
                    regret = candidates[1][0] - candidates[0][0]
                else:
                    regret = 0.0
                if regret > best_regret:
                    best_regret = regret
                    best_client = client
                    best_route_idx, best_pos = candidates[0][1], candidates[0][2]
            if best_client is None or not progress:
                break
            routes[best_route_idx].insert(best_pos, best_client)
            loads[best_route_idx] += self.demands[best_client]
            remaining.remove(best_client)
        inserted = sum(len(r) for r in routes) - len(self.static)
        print(f"        regret3: insérés {inserted}/{len(self.dynamic)} clients")
        return routes

    # ---------- 5. k-NN (pondéré par capacité restante) ----------
    def knn_insertion(self, k=5):
        routes = self._fresh()
        loads = self._loads(routes)
        if not self.static:
            return self.cheapest_insertion()
        sxy = np.array([self.coords[c] for c in self.static])
        nbrs = NearestNeighbors(n_neighbors=min(k, len(sxy)), algorithm='ball_tree').fit(sxy)
        for client in self.dynamic:
            _, idxs = nbrs.kneighbors(np.array(self.coords[client]).reshape(1,-1))
            scores = defaultdict(float)
            for idx in idxs[0]:
                sc = self.static[idx]
                for ri, route in enumerate(routes):
                    if sc in route:
                        rem = self.capacity - loads[ri]
                        scores[ri] += rem
                        break
            inserted = False
            if scores:
                target = max(scores, key=scores.get)
                if loads[target] + self.demands[client] <= self.capacity:
                    p, _ = self._best_pos(routes[target], client)
                    routes[target].insert(p, client)
                    loads[target] += self.demands[client]
                    inserted = True
            if not inserted:
                self._cheapest_fb_penalty(routes, loads, client)
        inserted = sum(len(r) for r in routes) - len(self.static)
        print(f"        knn: insérés {inserted}/{len(self.dynamic)} clients")
        return routes

    # ---------- Classifieurs (SVM, Random Forest, Gradient Boosting) ----------
    def _fit_classifier(self, clf_class, **kwargs):
        client_list, route_assign = [], []
        for ri, route in enumerate(self.initial_routes):
            for c in route:
                client_list.append(c); route_assign.append(ri)
        if len(set(route_assign)) < 2:
            return None, None, None
        X, y = build_features(self.coords, self.demands, self.capacity,
                              client_list, route_assign, self.global_centroid)
        clf = clf_class(**kwargs)
        clf.fit(X, y)
        return clf, client_list, route_assign

    def _predict_and_insert(self, clf, routes, loads, client):
        cx, cy = self.coords[client]
        f2 = self.demands[client] / self.capacity
        f3 = np.hypot(cx - self.global_centroid[0], cy - self.global_centroid[1])
        if self.route_centroids:
            f4 = min(np.hypot(cx - rc[0], cy - rc[1]) for rc in self.route_centroids.values())
        else:
            f4 = 0.0
        pred = int(clf.predict([[cx, cy, f2, f3, f4]])[0])
        if 0 <= pred < self.K and loads[pred] + self.demands[client] <= self.capacity:
            p, _ = self._best_pos(routes[pred], client)
            routes[pred].insert(p, client)
            loads[pred] += self.demands[client]
        else:
            self._cheapest_fb_penalty(routes, loads, client)

    def svm_insertion(self):
        routes = self._fresh(); loads = self._loads(routes)
        clf, _, _ = self._fit_classifier(SVC, kernel='rbf', gamma='scale', C=1.0, random_state=42)
        if clf is None:
            return self.cheapest_insertion()
        for c in self.dynamic:
            self._predict_and_insert(clf, routes, loads, c)
        inserted = sum(len(r) for r in routes) - len(self.static)
        print(f"        svm: insérés {inserted}/{len(self.dynamic)} clients")
        return routes

    def kmeans_classifier_insertion(self):
        routes = self._fresh(); loads = self._loads(routes)
        centroids = np.array([
            np.mean([self.coords[c] for c in r], axis=0) if r else self.global_centroid.copy()
            for r in self.initial_routes
        ])
        for client in self.dynamic:
            order = np.argsort(np.linalg.norm(centroids - np.array(self.coords[client]), axis=1))
            inserted = False
            for target in order:
                if loads[target] + self.demands[client] <= self.capacity:
                    p, _ = self._best_pos(routes[target], client)
                    routes[target].insert(p, client)
                    loads[target] += self.demands[client]
                    inserted = True
                    break
            if not inserted:
                self._cheapest_fb_penalty(routes, loads, client)
        inserted = sum(len(r) for r in routes) - len(self.static)
        print(f"        kmeans_classifier: insérés {inserted}/{len(self.dynamic)} clients")
        return routes

    def random_forest_insertion(self, n_estimators=100):
        routes = self._fresh(); loads = self._loads(routes)
        clf, _, _ = self._fit_classifier(RandomForestClassifier,
                                         n_estimators=n_estimators,
                                         random_state=42, n_jobs=1)
        if clf is None:
            return self.cheapest_insertion()
        for c in self.dynamic:
            self._predict_and_insert(clf, routes, loads, c)
        inserted = sum(len(r) for r in routes) - len(self.static)
        print(f"        random_forest: insérés {inserted}/{len(self.dynamic)} clients")
        return routes

    def gradient_boosting_insertion(self, n_estimators=None, max_depth=None, learning_rate=0.1):
        routes = self._fresh(); loads = self._loads(routes)
        centroids = []
        for route in self.initial_routes:
            if route:
                cx = np.mean([self.coords[c][0] for c in route])
                cy = np.mean([self.coords[c][1] for c in route])
            else:
                cx, cy = 0.0, 0.0
            centroids.append((cx, cy))
        dist_matrix = {
            c: [np.hypot(self.coords[c][0]-cx, self.coords[c][1]-cy) for (cx,cy) in centroids]
            for c in range(len(self.coords))
        }
        def make_features(idx):
            x, y = self.coords[idx]
            return [x, y, self.demands[idx]] + dist_matrix[idx]
        X_train, y_train = [], []
        for ri, route in enumerate(self.initial_routes):
            for c in route:
                X_train.append(make_features(c)); y_train.append(ri)
        if len(X_train) == 0 or len(set(y_train)) < 2:
            return self.cheapest_insertion()
        le = LabelEncoder()
        y_enc = le.fit_transform(y_train)
        n_c = len(le.classes_)
        n_s = len(X_train)
        if n_estimators is None or max_depth is None:
            if n_c > 20 or (n_s / n_c) < 8:
                _n_est = n_estimators if n_estimators is not None else 50
                _depth = max_depth if max_depth is not None else 3
            else:
                _n_est = n_estimators if n_estimators is not None else 100
                _depth = max_depth if max_depth is not None else 5
        else:
            _n_est, _depth = n_estimators, max_depth
        model = xgb.XGBClassifier(n_estimators=_n_est, max_depth=_depth,
                                  learning_rate=learning_rate, random_state=42,
                                  verbosity=0, n_jobs=1)
        model.fit(X_train, y_enc)
        for client in self.dynamic:
            pred_enc = int(model.predict([make_features(client)])[0])
            pred = int(le.inverse_transform([pred_enc])[0])
            if 0 <= pred < self.K and loads[pred] + self.demands[client] <= self.capacity:
                pos, _ = self._best_pos(routes[pred], client)
                routes[pred].insert(pos, client)
                loads[pred] += self.demands[client]
            else:
                self._cheapest_fb_penalty(routes, loads, client)
        inserted = sum(len(r) for r in routes) - len(self.static)
        print(f"        gradient_boosting: insérés {inserted}/{len(self.dynamic)} clients")
        return routes

def run_insertion(bench, mkey, k=5):
    d = {
        "random": bench.random_insertion,
        "cheapest": bench.cheapest_insertion,
        "regret2": bench.regret2_insertion,
        "regret3": bench.regret3_insertion,
        "knn": lambda: bench.knn_insertion(k=k),
        "svm": bench.svm_insertion,
        "kmeans_classifier": bench.kmeans_classifier_insertion,
        "random_forest": bench.random_forest_insertion,
        "gradient_boosting": bench.gradient_boosting_insertion,
    }
    return d[mkey]()

# =============================================================================
# ANALYSE DES RÉSULTATS (CORRIGÉE)
# =============================================================================

def analyse_results():
    if not os.path.exists(OUTPUT_CSV):
        print("Aucun fichier de résultats à analyser.")
        return
    data = defaultdict(list)
    times = defaultdict(list)
    with open(OUTPUT_CSV, newline='') as f:
        for row in csv.DictReader(f):
            key = (row['instance'], row['insertion_method'])
            data[key].append(float(row['cost_after_reopt']))
            times[row['insertion_method']].append(float(row['insertion_time_s']))

    methods = [m for _, m in INSERTION_METHODS]
    instances = set(i for i,_ in data.keys())
    instances = sorted(instances)

    print("\n" + "="*110)
    print("TABLEAU RÉCAPITULATIF – COÛT FINAL MOYEN (30 runs)")
    print("="*110)
    hdr = f"{'Instance':<18}" + "".join(f"{m:>16}" for m in methods)
    print(hdr)
    for inst in instances:
        line = f"{inst:<18}"
        for m in methods:
            vals = data[(inst, m)]
            line += f"{np.mean(vals):>16.2f}" if vals else f"{'N/A':>16}"
        print(line)

    print("\n=== RANGS MOYENS (coût final) ===")
    from scipy.stats import rankdata
    ranks = defaultdict(list)
    for inst in instances:
        vals = [np.mean(data[(inst, m)]) if data[(inst, m)] else float('inf') for m in methods]
        for m, r in zip(methods, rankdata(vals)):
            ranks[m].append(r)
    for m in methods:
        print(f"  {m:<26}: avg rank = {np.mean(ranks[m]):.2f}  "
              f"wins = {sum(1 for r in ranks[m] if r==1.0)}/{len(instances)}")

    print("\n=== TEMPS D'INSERTION MOYEN (secondes) ===")
    for m in methods:
        t = times[m]
        if t:
            print(f"  {m:<26}: {np.mean(t):.6f} s ± {np.std(t):.6f}")

    print("\n=== COMPROMIS COÛT/TEMPS (score normalisé) ===")
    # CORRECTION : on prend la moyenne des moyennes par instance
    cost_means = {}
    for m in methods:
        instance_means = [np.mean(data[(inst, m)]) for inst in instances if data[(inst, m)]]
        cost_means[m] = np.mean(instance_means) if instance_means else 0.0
    time_means = {m: np.mean(times[m]) for m in methods}
    cost_min, cost_max = min(cost_means.values()), max(cost_means.values())
    time_min, time_max = min(time_means.values()), max(time_means.values())
    compromise = {}
    for m in methods:
        norm_cost = (cost_means[m] - cost_min) / (cost_max - cost_min) if cost_max > cost_min else 0
        norm_time = (time_means[m] - time_min) / (time_max - time_min) if time_max > time_min else 0
        compromise[m] = (norm_cost + norm_time) / 2
    sorted_comp = sorted(compromise.items(), key=lambda x: x[1])
    for m, score in sorted_comp:
        print(f"    {m:<26}: score = {score:.4f}")

