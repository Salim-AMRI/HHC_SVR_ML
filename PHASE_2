def build_features(coords, demands, capacity, client_list, route_assignments,
                   global_centroid=None):
    if not client_list:
        return np.array([]).reshape(0,5), []
    all_x = [coords[c][0] for c in client_list]
    all_y = [coords[c][1] for c in client_list]
    x_min, x_max = min(all_x), max(all_x)
    y_min, y_max = min(all_y), max(all_y)
    dx = max(x_max - x_min, 1e-9)
    dy = max(y_max - y_min, 1e-9)
    if global_centroid is None:
        global_centroid = np.array([np.mean(all_x), np.mean(all_y)])
    route_centroids = {}
    for c, r_idx in zip(client_list, route_assignments):
        route_centroids.setdefault(r_idx, []).append(coords[c])
    route_centroids = {r: np.mean(pts, axis=0) for r, pts in route_centroids.items()}
    X, y = [], []
    for c, r_idx in zip(client_list, route_assignments):
        cx, cy = coords[c]
        f0 = (cx - x_min) / dx
        f1 = (cy - y_min) / dy
        f2 = demands[c] / capacity
        f3 = np.hypot(cx - global_centroid[0], cy - global_centroid[1])
        rc = route_centroids.get(r_idx, global_centroid)
        f4 = np.hypot(cx - rc[0], cy - rc[1])
        X.append([f0, f1, f2, f3, f4])
        y.append(r_idx)
    return np.array(X), y

