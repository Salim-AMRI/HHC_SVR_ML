def main():
    fieldnames = [
        'instance', 'run', 'seed', 'n_static', 'n_dynamic',
        'phase1_cost', 'phase1_time_s',
        'insertion_method', 'cost_after_insertion', 'insertion_time_s',
        'cost_after_reopt', 'reopt_time_s', 'feasible'
    ]
    with open(OUTPUT_CSV, 'w', newline='') as f:
        csv.DictWriter(f, fieldnames=fieldnames).writeheader()

    for filename in INSTANCE_FILES:
        file_path = os.path.join(INSTANCE_DIR, filename)
        if not os.path.exists(file_path):
            print(f"Fichier {file_path} introuvable, instance ignorée.")
            continue
        try:
            coords, demands, dim, capacity, n_veh = load_instance(file_path)
        except Exception as e:
            print(f"Erreur chargement {filename}: {e}")
            continue

        D = precompute_distances(coords)
        print(f"\n{'='*60}\n{filename} | dim={dim} capacité={capacity} K={n_veh}")

        # Séparation 70/30
        np.random.seed(42)
        all_c = list(range(1, dim))
        np.random.shuffle(all_c)
        split = int(0.7 * len(all_c))
        static_c = sorted(all_c[:split])
        dynamic_c = sorted(all_c[split:])
        print(f"  statiques={len(static_c)} dynamiques={len(dynamic_c)}")
        total_demand_static = sum(demands[c] for c in static_c)
        total_cap = capacity * n_veh
        print(f"  Demande statique totale: {total_demand_static}, Capacité totale: {total_cap}")
        if total_demand_static > total_cap:
            print("  ⚠️ Instance infaisable (demande statique > capacité totale). Ignorée.")
            continue

        for ri, seed in enumerate(SEEDS):
            print(f"\nRun {ri+1}/{N_RUNS} (seed={seed})")
            # Phase 1
            t0 = time.time()
            init_routes, phase1_cost = phase1_optimization(
                coords, demands, D, capacity, n_veh, MAX_TIME_TABU, seed, static_c)
            phase1_time = time.time() - t0
            print(f"  Phase1 : cost={phase1_cost:.0f} time={phase1_time:.1f}s")

            for mkey, mname in INSERTION_METHODS:
                bench = InsertionBenchmark(coords, demands, D, capacity, static_c, dynamic_c, init_routes)
                t1 = time.time()
                routes_after_insert = run_insertion(bench, mkey, KNN_K)
                ins_time = time.time() - t1
                cost_after_insert = total_dist(routes_after_insert, D)

                # Ré-optimisation (sans _reduce_overload)
                solver = TabuSolver(coords, demands, D, capacity, n_veh, MAX_TIME_TABU, seed)
                solver.set_initial_solution(routes_after_insert)
                t2 = time.time()
                final_routes = solver.tabu_search()
                reopt_time = time.time() - t2
                cost_after_reopt = total_dist(final_routes, D)
                feasible = is_feasible(final_routes, demands, capacity)

                row = {
                    "instance": filename,
                    "run": ri+1,
                    "seed": seed,
                    "n_static": len(static_c),
                    "n_dynamic": len(dynamic_c),
                    "phase1_cost": round(phase1_cost, 2),
                    "phase1_time_s": round(phase1_time, 2),
                    "insertion_method": mname,
                    "cost_after_insertion": round(cost_after_insert, 2),
                    "insertion_time_s": round(ins_time, 4),
                    "cost_after_reopt": round(cost_after_reopt, 2),
                    "reopt_time_s": round(reopt_time, 2),
                    "feasible": int(feasible)
                }
                with open(OUTPUT_CSV, 'a', newline='') as f:
                    csv.DictWriter(f, fieldnames=fieldnames).writerow(row)
                print(f"    {mname:<22} after_insert={cost_after_insert:.0f} after_reopt={cost_after_reopt:.0f} feasible={feasible}")

    print(f"\nBenchmark principal terminé → {OUTPUT_CSV}")
    analyse_results()

if __name__ == '__main__':
    main()
