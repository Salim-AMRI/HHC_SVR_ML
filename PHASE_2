def phase1_optimization(coords, demands, D, capacity, num_vehicles, max_time, seed, clients):
    xy = np.array([coords[c] for c in clients])
    km = KMeans(n_clusters=num_vehicles, random_state=seed, n_init=10).fit(xy)
    routes = [[] for _ in range(num_vehicles)]
    for idx, lbl in enumerate(km.labels_):
        routes[lbl].append(clients[idx])
    # Réparation complète pour garantir faisabilité initiale
    solver_temp = TabuSolver(coords, demands, D, capacity, num_vehicles, max_time, seed)
    routes = solver_temp._repair_full(routes)
    # Tabu Search
    solver = TabuSolver(coords, demands, D, capacity, num_vehicles, max_time, seed)
    solver.set_initial_solution(routes)
    final_routes = solver.tabu_search()
    cost = total_dist(final_routes, D)
    feasible = is_feasible(final_routes, demands, capacity)
    print(f"    Phase1: cost={cost:.0f}, faisable={feasible}")
    if not feasible:
        loads = [sum(demands[c] for c in r) for r in final_routes]
        over = [i for i, l in enumerate(loads) if l > capacity]
        print(f"      Surcharges routes {over}")
    return final_routes, cost

