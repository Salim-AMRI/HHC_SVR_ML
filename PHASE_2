# =============================================================================

class TabuSolver:
    def __init__(self, coords, demands, D, capacity, num_vehicles, max_time, seed=42):
        self.coords = coords
        self.demands = demands
        self.D = D
        self.capacity = capacity
        self.num_vehicles = num_vehicles
        self.max_time = max_time
        self.seed = seed
        np.random.seed(seed)
        random.seed(seed)
        self.solution = None
        self.initial_solution = None
        self.pre_ts_cost = None

    def set_initial_solution(self, routes):
        self.solution = [r[:] for r in routes]
        self.initial_solution = self._freeze(self.solution)
        self.pre_ts_cost = total_dist(self.solution, self.D)

    @staticmethod
    def _freeze(sol): return tuple(tuple(r) for r in sol)
    @staticmethod
    def _unfreeze(frozen): return [list(r) for r in frozen]

    def _is_feasible(self, sol):
        return all(sum(self.demands[c] for c in r) <= self.capacity for r in sol)

    # -------------------- Ordre et 2-opt --------------------
    def _nn_order(self, route):
        cur, ordered, unvis = 0, [], set(route)
        while unvis:
            nxt = min(unvis, key=lambda x: self.D[cur, x])
            ordered.append(nxt); unvis.remove(nxt); cur = nxt
        return ordered

    def _two_opt(self, route):
        best = route[:]; bd = route_dist(best, self.D); improved = True
        max_iter = 50; it = 0
        while improved and it < max_iter:
            improved = False; it += 1
            for i in range(1, len(best)-1):
                for j in range(i+1, len(best)):
                    if j-i == 1: continue
                    new = best[:i] + best[i:j][::-1] + best[j:]
                    nd = route_dist(new, self.D)
                    if nd < bd: best, bd, improved = new, nd, True
        return best

    def _repair_full(self, sol):
        """Réparation complète + réordonnancement (fallback)."""
        s = [r[:] for r in sol]
        loads = [sum(self.demands[c] for c in r) for r in s]
        for _ in range(100):
            over = next((i for i, l in enumerate(loads) if l > self.capacity), None)
            if over is None: break
            client = max(s[over], key=lambda c: self.demands[c])
            target = min(range(len(s)), key=lambda i: loads[i])
            s[over].remove(client); s[target].append(client)
            loads[over] -= self.demands[client]; loads[target] += self.demands[client]
        for i, r in enumerate(s):
            if r: s[i] = self._two_opt(self._nn_order(r))
        return s

    def _force_feasible_strict(self, sol):
        """First Fit Decreasing – garantit faisabilité."""
        all_clients = [c for r in sol for c in r]
        all_clients.sort(key=lambda c: self.demands[c], reverse=True)
        new = [[] for _ in range(self.num_vehicles)]
        loads = [0] * self.num_vehicles
        for c in all_clients:
            placed = False
            for i in range(self.num_vehicles):
                if loads[i] + self.demands[c] <= self.capacity:
                    new[i].append(c); loads[i] += self.demands[c]; placed = True; break
            if not placed:
                i = min(range(self.num_vehicles), key=lambda x: loads[x])
                new[i].append(c); loads[i] += self.demands[c]
        return new

    # -------------------- Voisinage strictement faisable --------------------
    def _neighbors(self, sol, deadline):
        cands = []
        sol_list = [list(r) for r in sol]
        K = len(sol_list)
        loads = [sum(self.demands[c] for c in r) for r in sol_list]

        # Relocation
        for src in range(K):
            if time.time() > deadline: break
            for idx in range(len(sol_list[src])):
                if time.time() > deadline or len(cands) >= 400: break
                client = sol_list[src][idx]
                for dst in range(K):
                    if dst == src: continue
                    if loads[dst] + self.demands[client] > self.capacity: continue
                    bp, bi = 0, float('inf')
                    for pos in range(len(sol_list[dst])+1):
                        prev = sol_list[dst][pos-1] if pos>0 else 0
                        nxt  = sol_list[dst][pos]   if pos<len(sol_list[dst]) else 0
                        inc  = self.D[prev,client] + self.D[client,nxt] - self.D[prev,nxt]
                        if inc < bi: bi, bp = inc, pos
                    nb = [r[:] for r in sol_list]
                    nb[src] = sol_list[src][:idx] + sol_list[src][idx+1:]
                    nb[dst] = sol_list[dst][:bp] + [client] + sol_list[dst][bp:]
                    cands.append(self._freeze(nb))
                    if len(cands) >= 400: break
                if len(cands) >= 400: break
            if len(cands) >= 400: break

        # 2-opt intra
        for r in range(K):
            if time.time() > deadline or len(cands) >= 400: break
            route = sol_list[r]
            for i in range(1, len(route)-1):
                for j in range(i+1, len(route)):
                    if j-i == 1: continue
                    nb = [r[:] for r in sol_list]
                    nb[r] = route[:i] + route[i:j][::-1] + route[j:]
                    cands.append(self._freeze(nb))
                    if len(cands) >= 400: break
                if len(cands) >= 400: break
            if len(cands) >= 400: break

        # Swap inter-routes
        for i in range(K):
            if time.time() > deadline or len(cands) >= 400: break
            for j in range(i+1, K):
                if not sol_list[i] or not sol_list[j]: continue
                for ki in range(min(2, len(sol_list[i]))):
                    for kj in range(min(2, len(sol_list[j]))):
                        ci = sol_list[i][ki]; cj = sol_list[j][kj]
                        new_i = loads[i] - self.demands[ci] + self.demands[cj]
                        new_j = loads[j] - self.demands[cj] + self.demands[ci]
                        if new_i > self.capacity or new_j > self.capacity: continue
                        nb = [r[:] for r in sol_list]
                        nb[i][ki], nb[j][kj] = nb[j][kj], nb[i][ki]
                        cands.append(self._freeze(nb))
                        if len(cands) >= 400: break
                    if len(cands) >= 400: break
                if len(cands) >= 400: break
            if len(cands) >= 400: break

        return cands

    # -------------------- Tabu Search --------------------
    def tabu_search(self):
        if self.solution is None:
            raise ValueError("Solution initiale non définie.")
        # Assurer faisabilité de la solution initiale
        if not self._is_feasible(self.solution):
            self.solution = self._force_feasible_strict(self.solution)
            self.solution = self._repair_full(self.solution)

        start = time.time()
        deadline = start + self.max_time
        current = self._freeze(self.solution)
        best_sol = current
        best_cost = total_dist(self._unfreeze(best_sol), self.D)

        tabu_set = set()
        tabu_q = []
        tenure = max(7, min(15, self.num_vehicles // 3))

        while time.time() < deadline:
            nbrs = self._neighbors(self._unfreeze(current), deadline)
            if not nbrs: break

            bn, bnc = None, float('inf')
            for nb in nbrs:
                nb_sol = self._unfreeze(nb)
                if not self._is_feasible(nb_sol): continue
                c = total_dist(nb_sol, self.D)
                if nb in tabu_set and c >= best_cost: continue
                if c < bnc:
                    bnc, bn = c, nb

            if bn is None: break
            if bnc < best_cost:
                best_sol = bn
                best_cost = bnc

            tabu_set.add(current); tabu_q.append(current)
            if len(tabu_q) > tenure:
                tabu_set.discard(tabu_q.pop(0))
            current = bn

        final_sol = self._unfreeze(best_sol)
        if not self._is_feasible(final_sol):
            final_sol = self._force_feasible_strict(final_sol)
            final_sol = self._repair_full(final_sol)
        return final_sol

