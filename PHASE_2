def load_instance(filepath):
    with open(filepath, 'r') as f:
        content = f.read()

    cap_match = re.search(r'CAPACITY\s*:\s*(\d+)', content)
    if cap_match:
        capacity = int(cap_match.group(1))
    else:
        raise ValueError(f"Capacité non trouvée dans {filepath}")

    filename = os.path.basename(filepath)
    k_match = re.search(r'-k(\d+)', filename)
    if k_match:
        num_vehicles = int(k_match.group(1))
    else:
        raise ValueError(f"K non trouvé dans {filename}")

    coord_match = re.search(r'NODE_COORD_SECTION(.*?)DEMAND_SECTION', content, re.DOTALL)
    coords = []
    if coord_match:
        for line in coord_match.group(1).strip().split('\n'):
            parts = line.strip().split()
            if len(parts) >= 3:
                try:
                    coords.append((float(parts[1]), float(parts[2])))
                except:
                    pass
    else:
        raise ValueError("Section NODE_COORD_SECTION non trouvée")

    demand_match = re.search(r'DEMAND_SECTION(.*?)(?:DEPOT_SECTION|EOF)', content, re.DOTALL)
    demands = [0]
    if demand_match:
        for line in demand_match.group(1).strip().split('\n'):
            parts = line.strip().split()
            if len(parts) >= 2:
                try:
                    demands.append(int(parts[1]))
                except:
                    pass
    else:
        raise ValueError("Section DEMAND_SECTION non trouvée")

    dim = len(coords)
    while len(demands) < dim + 1:
        demands.append(0)
    demands = demands[:dim+1]
    demands[0] = 0
    return coords, demands, dim, capacity, num_vehicles

def precompute_distances(coords):
    n = len(coords)
    D = np.zeros((n, n))
    for i in range(n):
        for j in range(i+1, n):
            d = np.hypot(coords[i][0]-coords[j][0], coords[i][1]-coords[j][1])
            D[i,j] = D[j,i] = d
    return D

def route_dist(route, D):
    if not route:
        return 0.0
    d = D[0, route[0]]
    for i in range(len(route)-1):
        d += D[route[i], route[i+1]]
    d += D[route[-1], 0]
    return d

def total_dist(sol, D):
    return sum(route_dist(r, D) for r in sol)

def is_feasible(sol, demands, cap):
    return all(sum(demands[c] for c in r) <= cap for r in sol)

